# === EDU-PUBLISH Environment Variables ===

# --- Required (all modes) ---
SITE_URL=https://example.edu.cn

# --- Minimal deployment (Mode A) ---
PORT=8080

# --- Cloudflare deployment (Mode B) ---
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_PAGES_PROJECT=
CF_D1_DATABASE_ID=
CF_R2_BUCKET=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_ENDPOINT=

# --- View counts ---
VIEW_COUNT_BACKEND=none          # none | sqlite | d1
SQLITE_DB_PATH=./data/views.db

# --- Automation stack (Mode C) ---
NAPCAT_ACCOUNT=
ASTRBOT_DASHBOARD_PORT=6185
OPENCLAW_WORKSPACE=/opt/edu-publish
